POSTGRES_USER=voxlibris
POSTGRES_PASSWORD=voxlibris
POSTGRES_DB=voxlibris

SESSION_SECRET=change-me-to-a-random-string

# Optional: OpenRouter for LLM-powered speaker detection
AI_INTEGRATIONS_OPENROUTER_BASE_URL=
AI_INTEGRATIONS_OPENROUTER_API_KEY=

# Optional: Port mapping
APP_PORT=5000
DB_PORT=5432

# ── Logging ────────────────────────────────────────────────────────────────────

# Console log level (Python backend).
# Valid levels (lowest → highest severity):
#   TRACE | DEBUG | INFO | SUCCESS | WARNING | ERROR | CRITICAL
# Defaults to DEBUG in development, INFO in production.
LOG_LEVEL=DEBUG

# Directory where rotating log files are written (relative to the app root,
# or an absolute path). The folder is created automatically if it doesn't exist.
# Defaults to "logs".
LOG_DIR=logs

# ── Optional: log to a PostgreSQL table ────────────────────────────────────────
# When set, WARNING-and-above entries are written to an `app_logs` table that
# is auto-created in the target database.
# Format: postgresql://user:password@host:port/dbname
#LOG_POSTGRES_URL=postgresql://user:password@localhost:5432/dbname

# ── Optional: log to a MariaDB / MySQL table ───────────────────────────────────
# WARNING-and-above entries are written to an `app_logs` table.
# Requires: pip install mysql-connector-python
# Format: user:password@host:port/dbname
#LOG_MARIADB_DSN=user:password@localhost:3306/dbname

# ── Optional: forward to a syslog / syslog-ng server (UDP) ────────────────────
# WARNING-and-above entries are forwarded via UDP syslog.
#LOG_SYSLOG_HOST=localhost
# Defaults to 514 if not set.
#LOG_SYSLOG_PORT=514

# ── Optional: email alerts for CRITICAL events ─────────────────────────────────
# All six vars must be set to activate the email sink.
#LOG_SMTP_HOST=smtp.example.com
# Defaults to 587 (STARTTLS) if not set.
#LOG_SMTP_PORT=587
#LOG_SMTP_USER=alerts@example.com
#LOG_SMTP_PASS=smtp-password
#LOG_SMTP_FROM=alerts@example.com
#LOG_SMTP_TO=oncall@example.com
